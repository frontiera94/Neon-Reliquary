  "feats": [
    {
      "id": "sneak-attack-ability",
      "index": 1,
      "name": "Sneak Attack",
      "shortDesc": "The rogue's attack deals extra damage when she catches opponents off guard.",
      "fullDesc": "If a rogue can catch an opponent when he is unable to defend himself effectively, she can strike a vital spot for extra damage. The rogue's attack deals extra damage any time her target would be denied a Dexterity bonus to AC.",
      "bonusValue": 4,
      "bonusMax": 8,
      "bonusLabel": "Damage Dice"
    },
    {
      "id": "trapfinding",
      "index": 2,
      "name": "Trapfinding",
      "shortDesc": "A rogue adds 1/2 her level on Perception checks and Disable Device checks.",
      "fullDesc": "A rogue adds 1/2 her level on Perception skill checks made to locate traps and on Disable Device skill checks (minimum +1). A rogue can use Disable Device to disarm magic traps."
    },
    {
      "id": "evasion-feat",
      "index": 3,
      "name": "Evasion",
      "shortDesc": "If a rogue makes a successful Reflex save, she takes no damage.",
      "fullDesc": "At 2nd level and higher, a rogue can avoid even magical and unusual attacks with great agility. If she makes a successful Reflex saving throw against an attack that normally deals half damage on a successful save, she instead takes no damage."
    }
  ],
