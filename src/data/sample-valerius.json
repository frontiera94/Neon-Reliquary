    { "id": "divine-favor", "name": "Divine Favor", "level": 1, "school": "Evocation", "castingTime": "1 standard action", "range": "Personal", "duration": "1 minute/level", "savingThrow": "None", "spellResistance": false, "components": "V, S, DF", "description": "Calling upon the strength and wisdom of a deity, you gain a +1 luck bonus on attack and weapon damage rolls for every three caster levels you have (at least +1, maximum +3)." },
    { "id": "cure-light-wounds", "name": "Cure Light Wounds", "level": 1, "school": "Conjuration", "subschool": "Healing", "castingTime": "1 standard action", "range": "Touch", "duration": "Instantaneous", "savingThrow": "Will half (harmless)", "spellResistance": true, "components": "V, S", "description": "When laying your hand upon a living creature, you channel positive energy that cures 1d8 points of damage +1 point per caster level (maximum +5)." },
    { "id": "see-invisibility", "name": "See Invisibility", "level": 2, "school": "Divination", "castingTime": "1 standard action", "range": "Personal", "duration": "10 minutes/level", "savingThrow": "None", "spellResistance": false, "components": "V, S, M", "description": "You can see any objects or beings that are invisible within your range of vision, as well as any that are ethereal." },
    { "id": "hold-person", "name": "Hold Person", "level": 2, "school": "Enchantment", "subschool": "Compulsion", "castingTime": "1 standard action", "range": "Medium", "duration": "1 round/level", "savingThrow": "Will negates", "spellResistance": true, "components": "V, S, DF", "description": "The subject becomes paralyzed and freezes in place.", "isAttackSpell": true },
