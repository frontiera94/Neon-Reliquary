  "feats": [
    { "id": "stern-gaze", "index": 1, "name": "Stern Gaze", "shortDesc": "Inquisitors are skilled at sensing deception and intimidating their foes.", "fullDesc": "An Inquisitor receives a morale bonus on Intimidate and Sense Motive checks equal to 1/2 her Inquisitor level (minimum +1).", "bonusValue": 6, "bonusMax": 12, "bonusLabel": "Current Bonus" },
    { "id": "cunning-initiative", "index": 2, "name": "Cunning Initiative", "shortDesc": "You add your Wisdom modifier to your initiative checks.", "fullDesc": "At 2nd level, an inquisitor adds her Wisdom modifier on initiative checks, in addition to her Dexterity modifier." },
    { "id": "track", "index": 3, "name": "Track", "shortDesc": "An inquisitor adds half her level on Survival skill checks made to follow or identify tracks.", "fullDesc": "An inquisitor adds half her level on Survival skill checks made to follow or identify tracks.", "bonusValue": 6, "bonusMax": 12, "bonusLabel": "Track Bonus" },
    { "id": "solo-tactics", "index": 4, "name": "Solo Tactics", "shortDesc": "All of the inquisitor's allies are treated as if they had the same teamwork feats.", "fullDesc": "At 3rd level, all of the inquisitor's allies are treated as if they possessed the same teamwork feats as the inquisitor for the purpose of determining whether the inquisitor receives a bonus from her teamwork feats." },
    { "id": "bane-ability", "index": 5, "name": "Bane", "shortDesc": "The inquisitor's weapon glows with power against a designated foe type.", "fullDesc": "At 5th level, an inquisitor can imbue one of her weapons with the bane weapon special ability as a swift action. This lasts for a number of rounds per day equal to her inquisitor level.", "bonusValue": 12, "bonusMax": 12, "bonusLabel": "Rounds/Day" },
    { "id": "greater-bane", "index": 6, "name": "Greater Bane", "shortDesc": "The inquisitor's bane ability deals an additional 2d6 damage.", "fullDesc": "At 12th level, whenever an inquisitor uses her bane ability, the amount of bonus damage dealt by the weapon increases to 4d6." }
